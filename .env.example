# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — RDS in production, local Docker in development
DATABASE_URL="postgresql://postgres:password@localhost:5432/weave_dev"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# RS256 private key — used to SIGN access tokens (15-minute expiry)
# Generate: openssl genrsa -out private.pem 2048 && cat private.pem
JWT_SECRET="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# RS256 public key — used to VERIFY access tokens
# Generate: openssl rsa -in private.pem -pubout -out public.pem && cat public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# AES-256 encryption key for Google OAuth refresh tokens stored on User
# Must be exactly 32 bytes (256 bits). Generate: openssl rand -hex 32
APP_SECRET="change-me-generate-with-openssl-rand-hex-32"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Scopes needed: openid, email, profile, https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"
# Production: https://api.yourdomain.com/auth/google/callback

# ─── Cache ────────────────────────────────────────────────────────────────────
# Upstash Redis URL — used for refresh token storage and dashboard caching
REDIS_URL="rediss://default:<token>@<host>.upstash.io:6379"

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION="eu-central-1"

# SQS queue URLs — one per worker type
SQS_CALENDAR_SYNC_QUEUE_URL="https://sqs.eu-central-1.amazonaws.com/<account-id>/weave-calendar-sync"
SQS_INSIGHT_RECALC_QUEUE_URL="https://sqs.eu-central-1.amazonaws.com/<account-id>/weave-insight-recalc"
SQS_WEEKLY_DIGEST_QUEUE_URL="https://sqs.eu-central-1.amazonaws.com/<account-id>/weave-weekly-digest"
SQS_TAX_DEADLINE_QUEUE_URL="https://sqs.eu-central-1.amazonaws.com/<account-id>/weave-tax-deadline-seeder"

# SES verified sender address — used for weekly digest emails
SES_FROM_EMAIL="hello@weave.family"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
