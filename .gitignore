.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ─── Prisma ──────────────────────────────────────────────────
# Migration files are committed — only generated client is ignored
prisma/generated/

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Test & Coverage ─────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── AWS & Secrets ───────────────────────────────────────────
*.pem
*.key
credentials
