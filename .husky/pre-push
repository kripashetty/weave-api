branch=$(git symbolic-ref --short HEAD)
pattern='^(main|develop|feature|fix|hotfix|chore|docs|refactor|release)(/[a-z0-9][a-z0-9._-]*)?$'

if ! echo "$branch" | grep -Eq "$pattern"; then
  echo ""
  echo "  Branch name '$branch' does not follow the naming convention."
  echo ""
  echo "  Allowed formats:"
  echo "    main | develop"
  echo "    feature/<description>    e.g. feature/add-auth-flow"
  echo "    fix/<description>        e.g. fix/token-refresh-bug"
  echo "    hotfix/<description>     e.g. hotfix/null-pointer-crash"
  echo "    chore/<description>      e.g. chore/update-dependencies"
  echo "    docs/<description>       e.g. docs/api-reference"
  echo "    refactor/<description>   e.g. refactor/clean-up-prisma-queries"
  echo "    release/<version>        e.g. release/1.2.0"
  echo ""
  echo "  Use lowercase and hyphens only (no uppercase, no spaces, no slashes in description)."
  echo ""
  exit 1
fi
